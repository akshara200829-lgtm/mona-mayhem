---
import type { ActivePowerUp } from "../lib/types/powerup";
import { POWERUP_REGISTRY } from "../lib/powerups/registry";

interface Props {
  effects: ActivePowerUp[];
  side: "left" | "right";
}

const { effects, side } = Astro.props;
---

<div class={`active-effects active-effects--${side}`}>
  {effects.map((e) => {
    const def = POWERUP_REGISTRY[e.kind];
    const remaining = Math.max(0, e.duration - (Date.now() - e.activatedAt));
    const secs = Math.ceil(remaining / 1000);
    return (
      <div class="effect-badge" data-uid={e.uid} data-kind={e.kind}>
        <span class="effect-icon">{def.icon}</span>
        <span class="effect-timer">{secs}s</span>
      </div>
    );
  })}
</div>

<style>
.active-effects {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  min-height: 36px;
}

.active-effects--left { justify-content: flex-start; }
.active-effects--right { justify-content: flex-end; }

.effect-badge {
  display: flex;
  align-items: center;
  gap: 4px;
  background: rgba(0,0,0,0.6);
  border: 1px solid var(--accent1);
  padding: 4px 8px;
  animation: effectPulse 1s ease-in-out infinite;
  box-shadow: 0 0 8px var(--accent1-glow);
}

.effect-icon { font-size: 1rem; }

.effect-timer {
  font-family: 'Press Start 2P', monospace;
  font-size: 0.5rem;
  color: var(--accent1);
}

@keyframes effectPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}
</style>