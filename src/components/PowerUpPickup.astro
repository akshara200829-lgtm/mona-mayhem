---
import type { ArenaPowerUp } from "../lib/types/powerup";
import { POWERUP_REGISTRY } from "../lib/powerups/registry";

interface Props {
  powerUp: ArenaPowerUp;
}

const { powerUp } = Astro.props;
const def = POWERUP_REGISTRY[powerUp.kind];
---

<button
  class="powerup-pickup"
  data-uid={powerUp.uid}
  data-kind={powerUp.kind}
  title={def.description}
  aria-label={`Collect ${def.label}`}
>
  <span class="powerup-icon">{def.icon}</span>
  <span class="powerup-label">{def.label}</span>
</button>

<style>
.powerup-pickup {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  background: rgba(0, 0, 0, 0.7);
  border: 2px solid var(--accent1);
  padding: 8px 12px;
  cursor: pointer;
  font-family: 'Press Start 2P', monospace;
  animation: powerupFloat 1.5s ease-in-out infinite, powerupGlow 1.5s ease-in-out infinite;
  box-shadow: 0 0 12px var(--accent1-glow);
  transition: transform 0.15s;
}

.powerup-pickup:hover {
  transform: scale(1.15);
  box-shadow: 0 0 24px var(--accent1-glow);
}

.powerup-icon {
  font-size: 1.4rem;
}

.powerup-label {
  font-size: 0.45rem;
  color: var(--accent1);
  letter-spacing: 0.05em;
  white-space: nowrap;
}

@keyframes powerupFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6px); }
}

@keyframes powerupGlow {
  0%, 100% { box-shadow: 0 0 10px var(--accent1-glow); }
  50% { box-shadow: 0 0 24px var(--accent1-glow), 0 0 48px var(--accent1-glow); }
}
</style>